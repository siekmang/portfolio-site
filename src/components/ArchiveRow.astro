---
import type { Post } from '../../data/posts';

interface Props {
  posts: readonly Post[];
}

const { posts } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<section
  id="blog-archive"
  class="mb-0 scroll-mt-24 lg:mb-4 lg:scroll-mt-8"
  aria-labelledby="archive-heading"
>
  <h2 id="archive-heading" class="section-heading">Blog Archive</h2>
  <div class="overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full table-fixed border-spacing-0 text-left text-sm">
        <thead class="text-slate">
          <tr>
            <th scope="col" class="px-4 py-4 text-xs font-medium uppercase tracking-[0.25em]">
              Date
            </th>
            <th scope="col" class="px-4 py-4 text-xs font-medium uppercase tracking-[0.25em]">
              Title
            </th>
            <th scope="col" class="px-4 py-4 text-xs font-medium uppercase tracking-[0.25em]">
              Description
            </th>
          </tr>
        </thead>
        <tbody>
          {
            posts.map((post) => (
              <tr
                class="group border-t border-slate-700 hover:bg-slate-900/50 transition cursor-pointer"
                onclick={`location.href='${base}blog/${post.slug}'`}
                onkeydown={`if(event.key==='Enter' || event.key===' ') location.href='${base}blog/${post.slug}'`}
                role="link"
                tabindex="0"
              >
                <td class="whitespace-nowrap px-4 py-4 font-mono text-slate text-xs">{post.date}</td>
                <td class="px-4 py-4 text-slate">
                  <span class="font-medium title-text transition-colors group-hover:text-accent">{post.title}</span>
                </td>
                <td class="px-4 py-4 text-slate text-sm line-clamp-2">
                  <p class="m-0">{post.content}</p>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </div>
</section>
