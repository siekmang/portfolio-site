---
import type { Post } from '../../data/posts';

interface Props {
  post: Post;
  imageSrc?: string;
}

const { post, imageSrc: imageOverride } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const postHref = `${base}blog/${post.slug}`;

const imageSrc = imageOverride ?? (post.image ? (post.image.startsWith('/') ? post.image : `/${post.image}`) : undefined);
const cleanContent = post.content.replace(/<[^>]*>/g, '');
---

<a href={postHref} class="scroll-stat panel-card group space-y-6 block hover:opacity-80 transition-opacity">
  <article>
    <header>
      <h3 class="text-2xl font-semibold text-slate group-hover:text-accent transition-colors">
        {post.title}
      </h3>
      {post.date && <p class="mt-1 font-mono text-sm text-accent">{post.date}</p>}
    </header>

    {imageSrc && (
      <div class="w-full max-w-3xl overflow-hidden rounded-xl">
        <img
          src={imageSrc}
          alt={post.imageAlt ?? ''}
          class="w-full h-56 object-cover group-hover:scale-105 transition-transform"
          loading="lazy"
          decoding="async"
        />
      </div>
    )}

    <div class="space-y-4">
      <p class="body-copy line-clamp-3">{cleanContent}</p>
    </div>
  </article>
</a>

<style>
  .scroll-stat {
    opacity: 0;
    transform: translateY(20px) scale(0.95);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .scroll-stat.reveal {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
</style>

<script>
  function revealCards() {
    const cards = document.querySelectorAll('.scroll-stat');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const index = Array.from(cards).indexOf(entry.target);
          setTimeout(() => {
            entry.target.classList.add('reveal');
          }, (index % 3) * 150);

          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.15,
      rootMargin: '0px 0px -10px 0px'
    });

    cards.forEach(card => observer.observe(card));
  }

  revealCards();

  document.addEventListener('astro:after-swap', revealCards);
</script>
