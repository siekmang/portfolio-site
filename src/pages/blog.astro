---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import { site } from '@data/site';
import { posts } from '@data/posts';
import BlogCard from '../components/BlogCard.astro';
import { Icon } from 'astro-icon/components';

const title = `Blog | ${site.hero.name}`;
const description = `Thoughts about specific things I've worked on.`;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const homeHref = base;
---

<Layout title={title} description={description}>
  <p class="mb-8">
    <a
      href={homeHref}
      class="group flex items-center gap-2 text-sm text-accent transition hover:text-slate-light"
      data-astro-prefetch
    >
      <Icon name="ph:arrow-left" class="h-4 w-4 transition-transform group-hover:-translate-x-1" />
      {site.hero.name}
    </a>
  </p>

  <h1 class="mb-8 text-4xl font-bold tracking-tight text-white sm:text-4xl">Blog</h1>

  <p class="mb-10 max-w-prose body-copy">
    {site.blogArchivePage.intro}
  </p>

  <div class="space-y-4 mb-10">
    {posts.map((post) => (
      <BlogCard post={post} imageSrc={post.image ? `${base}${post.image}` : undefined} />
    ))}
  </div>
  <Footer></Footer>
</Layout>
