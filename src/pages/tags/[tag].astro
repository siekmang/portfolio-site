---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import { site } from '@data/site';
import { getAllTags, getPostsByTag } from '@data/posts';
import BlogCard from '../../components/BlogCard.astro';
import { Icon } from 'astro-icon/components';

export async function getStaticPaths() {
  const allTags = getAllTags();

  return allTags.map((tag) => {
    const filteredPosts = getPostsByTag(tag);
    return {
      params: { tag },
      props: { posts: filteredPosts, allTags },
    };
  });
}

const { tag } = Astro.params;
const { posts, allTags } = Astro.props;

const title = `Posts tagged #${tag} | ${site.hero.name}`;
const description = `Articles and thoughts categorized under #${tag}.`;

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const blogHref = `${base}blog`;
---

<Layout title={title} description={description}>
  <p class="mb-8">
    <a
      href={blogHref}
      class="group flex items-center gap-2 text-sm text-accent transition hover:text-slate-light"
      data-astro-prefetch
    >
      <Icon name="ph:arrow-left" class="h-4 w-4 transition-transform group-hover:-translate-x-1" />
      Back to all posts
    </a>
  </p>

  <h1 class="mb-4 text-4xl font-bold tracking-tight text-white sm:text-4xl">
    Posts tagged <span class="text-accent">#{tag}</span>
  </h1>

  <p class="mb-8 max-w-prose body-copy">
    Showing {posts.length} {posts.length === 1 ? 'post' : 'posts'} filed under #{tag}.
  </p>

  <!-- Tag Filter Cloud -->
  <ul class="mb-10 flex flex-wrap gap-2">
    <li>
      <a
        href={blogHref}
        class="inline-block rounded-full border border-accent/30 bg-accent/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-accent transition hover:bg-accent hover:text-slate-900"
      >
        All
      </a>
    </li>
    {allTags.map((currentTag) => {
      const isActive = currentTag.toLowerCase() === tag?.toLowerCase();
      return (
        <li>
          <a
            href={`${base}tags/${currentTag}`}
            class={`inline-block rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] transition ${
              isActive
                ? 'border-accent bg-accent text-slate-900'
                : 'border-accent/30 bg-accent/10 text-accent hover:bg-accent hover:text-slate-900'
            }`}
          >
            #{currentTag}
          </a>
        </li>
      );
    })}
  </ul>

  <h2 class="mb-1 text-3xl font-bold tracking-tight text-white sm:text-3xl">Posts</h2>
  <!-- Filtered Posts -->
  <div class="space-y-4 mb-10">
    {posts.map((post) => (
      <BlogCard post={post} imageSrc={post.image ? `${base}${post.image}` : undefined} />
    ))}
  </div>

  <Footer />
</Layout>
